---
interface Props {
  confidence: "verified" | "draft";
}

const { confidence } = Astro.props;
---

{confidence === "draft" && (
  <div class="confidence-draft">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div>
      <strong>Entwurf</strong> — Dieser Eintrag wird noch geprüft. Angaben können ungenau sein.
    </div>
  </div>
)}

{confidence === "verified" && (
  <div class="confidence-verified">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Geprüfter Eintrag
  </div>
)}
