---
import BaseLayout from "./BaseLayout.astro";
import ConfidenceBadge from "../components/ConfidenceBadge.astro";
import { getCategoryLabel } from "../data/categories";

interface Props {
  title: string;
  description: string;
  category: string;
  confidence: "verified" | "draft";
  lastUpdated?: string;
}

const { title, description, category, confidence, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="wiki-entry">
    <nav class="wiki-breadcrumb">
      <a href="/">Wiki</a>
      <span class="wiki-breadcrumb-sep">/</span>
      <a href={`/kategorie/${category}`}>{getCategoryLabel(category)}</a>
      <span class="wiki-breadcrumb-sep">/</span>
      <span>{title}</span>
    </nav>

    <div class="wiki-category" data-cat={category}>
      <span class="wiki-category-dot"></span>
      {getCategoryLabel(category)}
    </div>

    <h1 class="wiki-title">{title}</h1>

    <ConfidenceBadge confidence={confidence} />

    <div class="wiki-meta">
      {lastUpdated && (
        <span class="wiki-meta-item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Stand {lastUpdated}
        </span>
      )}
    </div>

    <div class="prose" data-pagefind-body>
      <slot />
    </div>
  </article>
</BaseLayout>
